<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <!-- Console Appender: вывод в консоль -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
        </Console>

        <!-- RollingFile Appender: вывод в файл с датой и временем -->
        <RollingFile name="RollingFile"
                     fileName="logs/application.log"
                     filePattern="logs/application-%d{yyyy-MM-dd_HH-mm-ss}-%i.log">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
            <Policies>
                <!-- Создавать новый файл каждый раз при запуске приложения -->
                <OnStartupTriggeringPolicy/>
                <!-- Или создавать новый файл каждый день -->
                <!-- <TimeBasedTriggeringPolicy interval="1" modulate="true"/> -->
            </Policies>
            <DefaultRolloverStrategy max="10"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <Root level="info">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
        </Root>
    </Loggers>
</Configuration>